# Hubstaff Personal Access Token — your long-lived, rotating credential (required).
# Create one at: https://developer.hubstaff.com/account/personal-access-tokens
HUBSTAFF_PERSONAL_ACCESS_TOKEN=

# --- Optional overrides (defaults shown) ---

# Organization used when a tool isn't given one (defaults to your first org).
# HUBSTAFF_DEFAULT_ORGANIZATION_ID=

# IANA timezone for "today"/"this week" and localizing naive start times.
# DEFAULT_TIMEZONE=UTC

# Where the rotated token cache is persisted.
# HUBSTAFF_TOKEN_STORE=~/.hubstaff-mcp/tokens.json

# Transport: "stdio" (local clients) or "http" (self-host). See README.
# MCP_TRANSPORT=stdio
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

# --- Advanced (rarely changed) ---
# MCP_SERVER_NAME=Hubstaff MCP
# HUBSTAFF_API_BASE=https://api.hubstaff.com/v2
# HUBSTAFF_TOKEN_URL=https://account.hubstaff.com/access_tokens
