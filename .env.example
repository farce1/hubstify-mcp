# Hubstaff Personal Access Token (a long-lived refresh token).
# Generate one at: https://developer.hubstaff.com/personal_access_tokens
HUBSTAFF_REFRESH_TOKEN=your_personal_access_token_here

# Optional: where to persist the rotated refresh/access token.
# Defaults to ~/.hubstify-mcp/token.json
# HUBSTAFF_TOKEN_STORE=/absolute/path/to/token.json
